# Torus-core RPC
TORUS_RPC_URL=http://127.0.0.1:8332
TORUS_RPC_USER=rpcuser
TORUS_RPC_PASS=rpcpassword
BRIDGE_ADDRESS=<torus-core bridge deposit address>

# Sepolia (Ethereum testnet)
SEPOLIA_RPC_URL=https://rpc.sepolia.org
SEPOLIA_PRIVATE_KEY=<deployer wallet private key, with or without 0x prefix>
WTRS_CONTRACT=0x4e01C78c4EE00B77df2f23bfEA70a1194A2E963a

# SP1 Prover Network (also reads from zk-bridge/.env)
SP1_PRIVATE_KEY=<sp1 prover network private key>

# Relayer settings
POLL_INTERVAL_SECS=30
MIN_CONFIRMATIONS=6
STATE_FILE=relayer_state.json
